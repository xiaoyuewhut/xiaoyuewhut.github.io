---
import BackToTop from "@components/control/BackToTop.astro";
import Footer from "@components/Footer.astro";
import Navbar from "@components/Navbar.astro";
import SideBar from "@components/widget/SideBar.astro";
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import ImageWrapper from "../components/misc/ImageWrapper.astro";
import TOC from "../components/widget/TOC.astro";
import { siteConfig } from "../config";
import {
	BANNER_HEIGHT,
	BANNER_HEIGHT_EXTEND,
	MAIN_PANEL_OVERLAPS_BANNER_HEIGHT,
} from "../constants/constants";
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	banner?: string;
	description?: string;
	lang?: string;
	setOGTypeArticle?: boolean;
	headings?: MarkdownHeading[];
	showHero?: boolean;
	showSidebar?: boolean;
	showLeftToc?: boolean;
}

const {
	title,
	banner,
	description,
	lang,
	setOGTypeArticle,
	headings = [],
	showHero = false,
	showSidebar = false,
	showLeftToc = false,
} = Astro.props;
const hasBannerCredit =
	siteConfig.banner.enable && siteConfig.banner.credit.enable;
const hasBannerLink = !!siteConfig.banner.credit.url;

const mainPanelTop = siteConfig.banner.enable
	? `calc(${BANNER_HEIGHT}vh - ${MAIN_PANEL_OVERLAPS_BANNER_HEIGHT}rem)`
	: "5.5rem";
---

<Layout title={title} banner={banner} description={description} lang={lang} setOGTypeArticle={setOGTypeArticle}>

<!-- Navbar -->
<slot slot="head" name="head"></slot>
<div id="top-row" class="z-[80] pointer-events-none fixed top-0 left-0 right-0 transition-all duration-700" class:list={[""]}>
    <div id="navbar-wrapper" class="pointer-events-auto transition-all max-w-[var(--page-width)] px-0 md:px-4 mx-auto">
        <Navbar></Navbar>
    </div>
</div>

<!-- Banner -->
{siteConfig.banner.enable && <div id="banner-wrapper" class={`absolute z-10 w-full transition duration-700 overflow-hidden`} style={`top: -${BANNER_HEIGHT_EXTEND}vh`}>
    <ImageWrapper id="banner" alt="Banner image of the blog" class:list={["object-cover h-full transition duration-700 opacity-0 scale-105"]}
                  src={siteConfig.banner.src} position={siteConfig.banner.position}
    >
    </ImageWrapper>
</div>}

<!-- Main content -->
<div class="absolute w-full z-30 pointer-events-none" style={`top: ${mainPanelTop}`}>
    <!-- The pointer-events-none here prevent blocking the click event of the TOC -->
    <main id="swup-container" class="transition-swup-fade w-full pointer-events-auto">
        {showHero && (
            <div id="hero-slot" class="relative w-full mb-4">
                <slot name="hero"></slot>
            </div>
        )}
        <div class="relative max-w-[var(--page-width)] mx-auto">
            <div
                id="main-grid"
                class:list={[
                    "transition duration-700 w-full left-0 right-0 grid grid-rows-[auto_1fr_auto] lg:grid-rows-[auto] mx-auto gap-4 px-0 md:px-4",
                    showSidebar
                        ? "grid-cols-[17.5rem_auto]"
                        : showLeftToc
                            ? "grid-cols-1 lg:grid-cols-[15rem_minmax(0,1fr)] xl:grid-cols-[16.5rem_minmax(0,1fr)]"
                            : "grid-cols-1",
                ]}
            >
                <!-- Banner image credit -->
                {hasBannerCredit && <a href={siteConfig.banner.credit.url} id="banner-credit" target="_blank" rel="noopener" aria-label="Visit image source"
                                       class:list={["group onload-animation transition-all absolute flex justify-center items-center rounded-full " +
                                       "px-3 right-4 -top-[3.25rem] bg-black/60 hover:bg-black/70 h-9", {"hover:pr-9 active:bg-black/80": hasBannerLink}]}
                >
                    <Icon class="text-white/75 text-[1.25rem] mr-1" name="material-symbols:copyright-outline-rounded" ></Icon>
                    <div class="text-white/75 text-xs">{siteConfig.banner.credit.text}</div>
                    <Icon class:list={["transition absolute text-[oklch(0.75_0.14_var(--hue))] right-4 text-[0.75rem] opacity-0",
                        {"group-hover:opacity-100": hasBannerLink}]}
                          name="fa6-solid:arrow-up-right-from-square">
                    </Icon>
                </a>}

                {showSidebar && (
                    <SideBar class="mb-4 row-start-2 row-end-3 col-span-2 lg:row-start-1 lg:row-end-2 lg:col-span-1 lg:max-w-[17.5rem] onload-animation" headings={headings}></SideBar>
                )}

                {showLeftToc && siteConfig.toc.enable && headings.length > 0 && (
                    <aside class="hidden lg:block row-start-1 row-end-2 col-span-1 self-start">
                        <div
                            id="toc-wrapper"
                            class="toc-left-shell onload-animation fixed top-24 z-20 hidden lg:block"
                            style="left: max(1rem, calc((100vw - var(--page-width)) / 2 + 1rem)); width: clamp(15rem, 24vw, 16.5rem);"
                        >
                            <div id="toc-inner-wrapper" class="max-h-[calc(100vh_-_8rem)] overflow-y-auto overflow-x-hidden hide-scrollbar rounded-[1.5rem] border border-[var(--card-border)] bg-[color:var(--card-bg)] px-3 py-4 shadow-[0_18px_48px_-30px_var(--card-shadow)]">
                                <div class="mb-3 px-2 text-sm font-semibold tracking-[0.18em] text-black/35 dark:text-white/35">目录</div>
                                <div id="toc" class="w-full transition-swup-fade">
                                    <TOC headings={headings}></TOC>
                                </div>
                            </div>
                        </div>
                    </aside>
                )}

                <div class:list={["overflow-hidden", showSidebar ? "col-span-2 lg:col-span-1" : "col-span-1"]}>
                    <div id="content-wrapper" class="onload-animation">
                        <!-- the overflow-hidden here prevent long text break the layout-->
                        <!-- make id different from windows.swup global property -->
                        <slot></slot>
                        <div class:list={["footer onload-animation hidden lg:block", showSidebar ? "col-span-2" : "col-span-1"]}>
                            <Footer></Footer>
                        </div>
                    </div>
                </div>

                <div class:list={["footer onload-animation block lg:hidden", showSidebar ? "col-span-2" : "col-span-1"]}>
                    <Footer></Footer>
                </div>
            </div>
        </div>

        <div class="relative max-w-[var(--page-width)] mx-auto">
            <BackToTop></BackToTop>
        </div>
    </main>
</div>

<!-- The things that should be under the banner, only the TOC for now -->
<div class="absolute w-full z-0 hidden 2xl:block">
    <div class="relative max-w-[var(--page-width)] mx-auto">
        <!-- TOC component -->
        {!showLeftToc && siteConfig.toc.enable && <div id="toc-wrapper" class:list={["hidden lg:block transition absolute top-0 -right-[var(--toc-width)] w-[var(--toc-width)] items-center",
            {"toc-hide": siteConfig.banner.enable}]}
        >
            <div id="toc-inner-wrapper" class="fixed top-14 w-[var(--toc-width)] h-[calc(100vh_-_20rem)] overflow-y-scroll overflow-x-hidden hide-scrollbar">
                <div id="toc" class="w-full h-full transition-swup-fade ">
                    <div class="h-8 w-full"></div>
                    <TOC headings={headings}></TOC>
                    <div class="h-8 w-full"></div>
                </div>
            </div>
        </div>}

        <!-- #toc needs to exist for Swup to work normally -->
        {(!siteConfig.toc.enable || showLeftToc) && <div id="toc"></div>}
    </div>
</div>
</Layout>
