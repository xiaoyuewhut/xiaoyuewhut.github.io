---
import StudiesPanel from "@components/StudiesPanel.svelte";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getCategoryList, getSortedPosts } from "@utils/content-utils";

const categories = await getCategoryList();
const posts = await getSortedPosts();

const postsByCategory = new Map();

for (const post of posts) {
	const category = post.data.category?.trim() || "未分类";
	const list = postsByCategory.get(category) || [];
	list.push(post);
	postsByCategory.set(category, list);
}

const sections = categories.map((category, index) => {
	const relatedPosts = postsByCategory.get(category.name) || [];

	return {
		id: `study-${index + 1}`,
		name: category.name,
		url: category.url,
		count: category.count,
		posts: relatedPosts.map((post) => ({
			slug: post.slug,
			title: post.data.title,
			description: post.data.description || "",
		})),
	};
});
---

<MainGridLayout title="专题" description="按专题浏览学习笔记。">
	<StudiesPanel sections={sections} client:load />
</MainGridLayout>
